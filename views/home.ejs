<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Medical Symptom Analyzer</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#f5f7fa;
        }

        .hero{
            background:white;
            border-radius:20px;
            padding:40px;
            box-shadow:0 0 20px rgba(0,0,0,.08);
        }

        .form-card{
            background:white;
            border-radius:20px;
            padding:30px;
            box-shadow:0 0 15px rgba(0,0,0,.08);
        }

        .result-card{
            display:none;
        }

        .section-title{
            font-weight:700;
            margin-bottom:20px;
        }

        .symptom-box{
            max-height:250px;
            overflow-y:auto;
        }
    </style>
</head>
<body>

<div class="container py-5">

    <!-- HERO -->

    <div class="hero mb-4">
        <h1 class="display-5 fw-bold">
            AI Medical Symptom Analyzer
        </h1>

        <p class="lead">
            Enter your symptoms and health details to receive an AI-powered preliminary assessment.
        </p>

        <div class="alert alert-warning mb-0">
            This tool is for informational purposes only and does not replace professional medical advice.
        </div>
    </div>

    <!-- FORM -->

    <div class="form-card">

        <h3 class="section-title">
            Patient Information
        </h3>

        <form id="diagnosisForm">

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label class="form-label">Age</label>
                    <input type="number"
                           class="form-control"
                           id="age"
                           required>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Gender</label>

                    <select class="form-select" id="gender">
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Severity</label>

                    <select class="form-select" id="severity">
                        <option>Mild</option>
                        <option>Moderate</option>
                        <option>Severe</option>
                    </select>
                </div>

            </div>

            <!-- Symptoms -->

            <h3 class="section-title mt-4">
                Symptoms
            </h3>

            <div class="row symptom-box">

                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input symptom"
                               type="checkbox"
                               value="Fever">
                        <label class="form-check-label">
                            Fever
                        </label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input symptom"
                               type="checkbox"
                               value="Headache">
                        <label class="form-check-label">
                            Headache
                        </label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input symptom"
                               type="checkbox"
                               value="Cough">
                        <label class="form-check-label">
                            Cough
                        </label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input symptom"
                               type="checkbox"
                               value="Body Pain">
                        <label class="form-check-label">
                            Body Pain
                        </label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input symptom"
                               type="checkbox"
                               value="Vomiting">
                        <label class="form-check-label">
                            Vomiting
                        </label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input symptom"
                               type="checkbox"
                               value="Diarrhea">
                        <label class="form-check-label">
                            Diarrhea
                        </label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input symptom"
                               type="checkbox"
                               value="Chest Pain">
                        <label class="form-check-label">
                            Chest Pain
                        </label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input symptom"
                               type="checkbox"
                               value="Breathing Difficulty">
                        <label class="form-check-label">
                            Breathing Difficulty
                        </label>
                    </div>
                </div>

            </div>

            <!-- Duration -->

            <div class="mt-4">
                <label class="form-label">
                    Symptom Duration
                </label>

                <select class="form-select" id="duration">
                    <option>Less than 24 hours</option>
                    <option>1 - 3 days</option>
                    <option>4 - 7 days</option>
                    <option>1 - 2 weeks</option>
                    <option>More than 2 weeks</option>
                </select>
            </div>

            <!-- Medical History -->

            <div class="mt-4">
                <label class="form-label">
                    Existing Medical Conditions
                </label>

                <textarea
                        id="conditions"
                        class="form-control"
                        rows="3"
                        placeholder="Diabetes, Asthma, Hypertension..."></textarea>
            </div>

            <div class="mt-4">
                <label class="form-label">
                    Current Medications
                </label>

                <textarea
                        id="medications"
                        class="form-control"
                        rows="3"></textarea>
            </div>

            <div class="mt-4">
                <label class="form-label">
                    Additional Notes
                </label>

                <textarea
                        id="notes"
                        class="form-control"
                        rows="4"
                        placeholder="Describe your condition in detail..."></textarea>
            </div>

            <button type="button" onclick="analyzeData()" class="btn btn-primary btn-lg mt-4">Analyze Symptoms</button>

        </form>

    </div>

    <!-- RESULTS -->

    <div
            id="resultsSection"
            class="form-card result-card mt-4">

        <h3 class="section-title">
            Assessment Results
        </h3>

        <div id="resultsContent">

            <div class="alert alert-info">
                Results will appear here after analysis.
            </div>

        </div>

    </div>

</div>

<script>

    async function analyzeData(){

            const symptoms = [];

            document
                .querySelectorAll('.symptom:checked')
                .forEach(cb => symptoms.push(cb.value));

            const payload = {
                age: document.getElementById('age').value,
                gender: document.getElementById('gender').value,
                severity: document.getElementById('severity').value,
                symptoms,
                duration: document.getElementById('duration').value,
                conditions: document.getElementById('conditions').value,
                medications: document.getElementById('medications').value,
                notes: document.getElementById('notes').value
            };

        const response = await fetch('/analyze', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        });

        const data = await response.json();

        console.log(data);

        const result = data.result;

        let conditionsHTML = '';

        result.possibleConditions.forEach(condition => {

            conditionsHTML += `
        <div class="card mb-3">
            <div class="card-body">
                <h5>${condition.name}</h5>

                <span class="badge bg-primary">
                    ${condition.confidence}
                </span>

                <p class="mt-2">
                    ${condition.reason}
                </p>
            </div>
        </div>
    `;
        });


        let redFlagsHTML = '';

        result.redFlags.forEach(flag => {

            redFlagsHTML += `
        <li>${flag}</li>
    `;
        });


        document.getElementById('resultsContent').innerHTML = `

    <h4>Possible Conditions</h4>

    ${conditionsHTML}

    <hr>

    <h4>Urgency</h4>

    <div class="alert alert-warning">
        ${result.urgency}
    </div>

    <h4>Recommended Specialist</h4>

    <div class="alert alert-info">
        ${result.specialist}
    </div>

    <h4>Red Flags</h4>

    <ul>
        ${redFlagsHTML}
    </ul>
`;

            document
                .getElementById('resultsSection')
                .style.display = 'block';
        }

</script>

</body>
</html>